{
    "parser_settings": {
        "version": "omni.2.1",
        "file_format_type": "fixedlength2"
    },
    "file_declaration": {
        "envelopes": [
            {
                "name": "header",
                "header": "^HDR",
                "columns": [
                    { "name": "record_type", "start_pos": 1, "length": 3 },
                    { "name": "batch_date", "start_pos": 4, "length": 8 },
                    { "name": "batch_id", "start_pos": 12, "length": 8 }
                ]
            },
            {
                "name": "transaction",
                "is_target": true,
                "header": "^TXN",
                "columns": [
                    { "name": "record_type", "start_pos": 1, "length": 3 },
                    { "name": "txn_id", "start_pos": 4, "length": 5 },
                    { "name": "account_num", "start_pos": 9, "length": 5 },
                    { "name": "last_name", "start_pos": 14, "length": 10 },
                    { "name": "first_name", "start_pos": 24, "length": 10 },
                    { "name": "amount_cents", "start_pos": 34, "length": 8 },
                    { "name": "currency", "start_pos": 42, "length": 3 },
                    { "name": "timestamp", "start_pos": 45, "length": 14 }
                ]
            },
            {
                "name": "trailer",
                "header": "^TRL",
                "columns": [
                    { "name": "record_type", "start_pos": 1, "length": 3 },
                    { "name": "record_count", "start_pos": 4, "length": 6 },
                    { "name": "total_amount", "start_pos": 10, "length": 10 }
                ]
            }
        ]
    },
    "writer_settings": {
        "version": "omni.1.0",
        "file_format_type": "csv"
    },
    "output_declaration": {
        "delimiter": ",",
        "columns": [
            { "name": "transaction_id", "path": "transaction_id" },
            { "name": "customer_name", "path": "customer_name" },
            { "name": "account", "path": "account" },
            { "name": "amount_usd", "path": "amount_usd" },
            { "name": "currency_code", "path": "currency_code" },
            { "name": "transaction_date", "path": "transaction_date" },
            { "name": "description", "path": "description" }
        ]
    },
    "transform_declarations": {
        "FINAL_OUTPUT": {
            "object": {
                "transaction_id": {
                    "custom_func": {
                        "name": "javascript",
                        "args": [
                            { "const": "'TXN-' + txn.padStart(10, '0')" },
                            { "const": "txn" },
                            { "xpath": "txn_id" }
                        ]
                    }
                },
                "customer_name": {
                    "custom_func": {
                        "name": "javascript",
                        "args": [
                            { "const": "last.trim() + ', ' + first.trim()" },
                            { "const": "last" },
                            { "xpath": "last_name" },
                            { "const": "first" },
                            { "xpath": "first_name" }
                        ]
                    }
                },
                "account": {
                    "xpath": "account_num"
                },
                "amount_usd": {
                    "custom_func": {
                        "name": "javascript",
                        "args": [
                            { "const": "curr === 'USD' ? (cents / 100.0).toFixed(2) : (cents / 100.0 * 0.75).toFixed(2)" },
                            { "const": "cents" },
                            { "xpath": "amount_cents", "type": "int" },
                            { "const": "curr" },
                            { "xpath": "currency" }
                        ]
                    }
                },
                "currency_code": {
                    "xpath": "currency"
                },
                "transaction_date": {
                    "custom_func": {
                        "name": "javascript",
                        "args": [
                            { "const": "ts.substring(0,4) + '-' + ts.substring(4,6) + '-' + ts.substring(6,8) + ' ' + ts.substring(8,10) + ':' + ts.substring(10,12) + ':' + ts.substring(12,14)" },
                            { "const": "ts" },
                            { "xpath": "timestamp" }
                        ]
                    }
                },
                "description": {
                    "custom_func": {
                        "name": "javascript",
                        "args": [
                            { "const": "'Payment from account ' + acct + ' in ' + curr" },
                            { "const": "acct" },
                            { "xpath": "account_num" },
                            { "const": "curr" },
                            { "xpath": "currency" }
                        ]
                    }
                }
            }
        }
    }
}
